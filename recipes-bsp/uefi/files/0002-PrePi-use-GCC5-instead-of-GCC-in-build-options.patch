From 7572b118c3a7e7e65bbe6441e221f9c39a16a476 Mon Sep 17 00:00:00 2001
From: Ilies CHERGUI <ichergui@nvidia.com>
Date: Wed, 18 Mar 2026 07:30:29 -0700
Subject: [PATCH] PrePi: use GCC5 instead of GCC in build options

Upstream-Status: Pending
Signed-off-by: Matt Madison <matt@madison.systems>
---
 Silicon/NVIDIA/PrePi/PrePi.inf | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/Silicon/NVIDIA/PrePi/PrePi.inf b/Silicon/NVIDIA/PrePi/PrePi.inf
index 1f75c87ad..be1b20f09 100644
--- a/Silicon/NVIDIA/PrePi/PrePi.inf
+++ b/Silicon/NVIDIA/PrePi/PrePi.inf
@@ -94,5 +94,5 @@
   gNVIDIATokenSpaceGuid.PcdTegraUtcUartAddress
 
 [BuildOptions]
-  *_GCC_*_DLINK_FLAGS = -pie -Wl,-T,$(MODULE_DIR)/Scripts/PrePi-PIE.lds
+  *_GCC5_*_DLINK_FLAGS = -pie -Wl,-T,$(MODULE_DIR)/Scripts/PrePi-PIE.lds
   *_CLANGDWARF_*_DLINK_FLAGS = -pie -Wl,-T,$(MODULE_DIR)/Scripts/PrePi-PIE-clang.lds
