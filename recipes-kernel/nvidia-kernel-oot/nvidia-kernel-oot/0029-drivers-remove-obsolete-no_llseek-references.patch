 #include <linux/nvhost.h>
@@ -129,7 +130,9 @@ static int nvcsi_release(struct inode *inode, struct file *file)
 
 const struct file_operations tegra_nvcsi_ctrl_ops = {
 	.owner = THIS_MODULE,
+#if LINUX_VERSION_CODE < KERNEL_VERSION(6, 0, 0)
