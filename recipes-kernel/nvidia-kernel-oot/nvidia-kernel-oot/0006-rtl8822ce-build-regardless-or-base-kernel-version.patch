From 83b41d705f8e35e8fb887ca265fc36b2720af8cd Mon Sep 17 00:00:00 2001
From: Kurt Kiefer <kekiefer@gmail.com>
Date: Mon, 26 Aug 2024 12:51:34 -0700
Subject: [PATCH] rtl8822ce: build regardless or base kernel version

Signed-off-by: Kurt Kiefer <kekiefer@gmail.com>
---
 nvidia-oot/drivers/net/wireless/realtek/Makefile           | 2 --
 nvidia-oot/drivers/net/wireless/realtek/rtl8822ce/Makefile | 1 +
 2 files changed, 1 insertion(+), 2 deletions(-)

diff --git a/nvidia-oot/drivers/net/wireless/realtek/Makefile b/nvidia-oot/drivers/net/wireless/realtek/Makefile
index 7d4e780..cf8df8f 100644
--- a/nvidia-oot/drivers/net/wireless/realtek/Makefile
+++ b/nvidia-oot/drivers/net/wireless/realtek/Makefile
@@ -2,7 +2,5 @@
 # Copyright (c) 2022, NVIDIA CORPORATION.  All rights reserved.
 
 ifeq ($(findstring ack_src,$(NV_BUILD_KERNEL_OPTIONS)),)
-ifeq ($(VERSION).$(PATCHLEVEL),5.15)
 obj-m += rtl8822ce/
 endif
-endif
diff --git a/nvidia-oot/drivers/net/wireless/realtek/rtl8822ce/Makefile b/nvidia-oot/drivers/net/wireless/realtek/rtl8822ce/Makefile
index 3cab6b3..1b7bcbf 100644
--- a/nvidia-oot/drivers/net/wireless/realtek/rtl8822ce/Makefile
+++ b/nvidia-oot/drivers/net/wireless/realtek/rtl8822ce/Makefile
@@ -15,6 +15,7 @@ EXTRA_CFLAGS += -Wno-unused-variable
 #EXTRA_CFLAGS += -Wno-unused
 #EXTRA_CFLAGS += -Wno-uninitialized
 EXTRA_CFLAGS += -Wno-missing-prototypes
+EXTRA_CFLAGS += -Wno-stringop-overread
 
 GCC_VER_49 := $(shell echo `$(CC) -dumpversion | cut -f1-2 -d.` \>= 4.9 | bc )
 ifeq ($(GCC_VER_49),1)
