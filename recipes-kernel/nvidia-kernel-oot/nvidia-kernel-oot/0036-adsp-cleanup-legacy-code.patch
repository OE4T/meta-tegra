-int adsp_lpthread_init(bool is_adsp_suspended)
-{
-	nvadsp_app_handle_t handle;
-	nvadsp_app_info_t *app_info;
-	int ret;
-
-	handle = nvadsp_app_load("adsp_lpthread", "adsp_lpthread.elf");
