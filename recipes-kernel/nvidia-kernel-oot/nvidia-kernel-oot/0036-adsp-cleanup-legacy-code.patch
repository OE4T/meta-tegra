index 033a8e50..00000000
--- a/drivers/platform/tegra/nvadsp/adsp_cpustat.c
+++ /dev/null
@@ -1,330 +0,0 @@
-/*
- * Copyright (C) 2015-2016, NVIDIA Corporation. All rights reserved.
- *
