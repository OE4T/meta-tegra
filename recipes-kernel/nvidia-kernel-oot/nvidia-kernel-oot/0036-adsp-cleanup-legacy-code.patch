-		actmon_devices[i]->device = &pdev->dev;
-		ret = actmon_dev_probe(actmon_devices[i]);
-		dev_dbg(&pdev->dev, "%s actmon: %s probe (%d)\n",
-		actmon_devices[i]->clk_name, ret ? "Failed" : "Completed", ret);
