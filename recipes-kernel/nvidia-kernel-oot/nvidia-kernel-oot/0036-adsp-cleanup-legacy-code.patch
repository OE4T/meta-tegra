-	adsp_lpthread =
-		(struct adsp_lpthread_shared_state_t *)app_info->mem.shared;
-	ret = nvadsp_mbox_open(&mbox, &adsp_lpthread->mbox_id,
-		"adsp_lpthread", NULL, NULL);
