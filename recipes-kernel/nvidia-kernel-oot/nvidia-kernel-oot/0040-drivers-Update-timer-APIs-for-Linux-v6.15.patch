 					if (pdev_data->timer_inited) {
 						pdev_data->timer_inited = false;
+#if defined(NV_TIMER_DELETE_PRESENT) /* Linux v6.15 */
+						timer_delete_sync(&pdev_data->timer);
+#else
 						del_timer_sync(&pdev_data->timer);
+#endif
 					}
 					if (!pdev_data->irq_registered) {
