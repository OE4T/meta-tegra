+
         status = nv_suspend_devices(pm_action, nv_system_pm_action_depth);
         if (status != NV_OK)
         {
-            up_write(&nv_system_pm_lock);
+            atomic_set(&nv_wait_flag, 0);
+            wake_up_all(&nv_system_pm_wq);
             goto done;
         }
     }
