     if (retval < 0)
     {
         single_release(inode, file);
@@ -910,7 +915,8 @@ nv_procfs_close_unbind_lock(
     }
 
 done:
-    up_read(&nv_system_pm_lock);
+    atomic_set(&nv_wait_flag, 0);
+    wake_up_all(&nv_system_pm_wq);
 
     single_release(inode, file);
 
@@ -1095,7 +1101,8 @@ nv_procfs_open_offline_pages(
         return retval;
     }
 
