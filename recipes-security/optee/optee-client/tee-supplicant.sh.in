#!/bin/sh

NAME=tee-supplicant
PATH=@stripped_path@
DESC="OP-TEE Supplicant"

DAEMON=@sbindir@/$NAME
OPTARGS=
FTPM_ENABLED="@OPTEE_ENABLE_FTPM@"

test -f $DAEMON || exit 0

test -f @sysconfdir@/default/$NAME && . @sysconfdir@/default/$NAME
test -f @sysconfdir@/default/rcS && . @sysconfdir@/default/rcS

SSD_OPTIONS="--oknodo --quiet --exec $DAEMON -- -d $OPTARGS"

set -e

case $1 in
    start)
	    echo -n "Starting $DESC: "
	    start-stop-daemon --start $SSD_OPTIONS
        echo "${DAEMON##*/}."
        if [ "${FTPM_ENABLED}" = "1" ]; then
            echo "Loading tpm_ftpm_tee"
            modprobe -v --ignore-install tpm_ftpm_tee
        fi
        ;;
    stop)
        if [ "${FTPM_ENABLED}" = "1" ]; then
            echo "Unloading tpm_ftpm_tee"
            modprobe -v -r tpm_ftpm_tee
        fi
	    echo -n "Stopping $DESC: "
	    start-stop-daemon --stop $SSD_OPTIONS
        echo "${DAEMON##*/}."
        ;;
    restart|force-reload)
	    $0 stop
	    sleep 1
	    $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|force-reload}" >&2
        exit 1
        ;;
esac

exit 0
