@@ -8383,7 +8383,7 @@ static const uint8_t mac_data_sha3_512_out1[] = {
  * GM/T 0042-2015
  * Section D.3 Test vector 1
  */
-static const uint8_t mac_data_sm3_d31_in[112] =
