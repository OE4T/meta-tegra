 # Function to setup installation for regular samples
 # This should be called after all targets are defined
 function(setup_samples_install)
+    # OE cross-build path: CMAKE_INSTALL_CUDA_SAMPLES is set by the OE recipe.
+    # Use standard install(TARGETS) so OE's do_install controls the destination.
+    if(DEFINED CMAKE_INSTALL_CUDA_SAMPLES)
+        get_directory_property(_targets BUILDSYSTEM_TARGETS)
+        foreach(_t IN LISTS _targets)
+            get_target_property(_type ${_t} TYPE)
+            if(_type STREQUAL "EXECUTABLE")
+                install(TARGETS ${_t} RUNTIME DESTINATION ${CMAKE_INSTALL_CUDA_SAMPLES})
+            endif()
+        endforeach()
+        return()
+    endif()
+
