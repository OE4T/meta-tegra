@@ -70,7 +97,7 @@ _CCCL_NODISCARD _LIBCUDACXX_HIDE_FROM_ABI constexpr bool isfinite(double __x) no
 #else // ^^^ _CCCL_BUILTIN_ISFINITE ^^^ / vvv !_CCCL_BUILTIN_ISFINITE vvv
   if (!_CUDA_VSTD::__cccl_default_is_constant_evaluated())
   {
-    return ::isfinite(__x);
+    return ::__cccl_isfinite_runtime(__x);
   }
 #  if _LIBCUDACXX_HAS_CONSTEXPR_BIT_CAST()
   return (_CUDA_VSTD::__fp_get_storage(__x) & __fp_exp_mask_v<double>) != __fp_exp_mask_v<double>;
@@ -156,4 +183,9 @@ _CCCL_NODISCARD _LIBCUDACXX_HIDE_FROM_ABI constexpr bool isfinite(_Tp) noexcept
 
 _LIBCUDACXX_END_NAMESPACE_STD
 
+#ifdef _CCCL_POP_MACRO_isfinite
+#  pragma pop_macro("isfinite")
