 .../include/cccl/cuda/std/__cmath/isfinite.h  |  38 ++++-
 .../include/cccl/cuda/std/__cmath/isinf.h     |  38 ++++-
 .../include/cccl/cuda/std/__cmath/isnan.h     |  34 +++-
