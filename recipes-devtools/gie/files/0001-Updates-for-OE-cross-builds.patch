From 794887df0224f79570012de1fe63c31c3de7e661 Mon Sep 17 00:00:00 2001
From: Ilies CHERGUI <ichergui@nvidia.com>
Date: Mon, 30 Mar 2026 12:33:18 -0700
Subject: [PATCH] Updates for OE cross builds

- Deprecated sampleCharRNN.

Upstream-Status: Inappropriate [oe-specific]

Signed-off-by: Ilies CHERGUI <ichergui@nvidia.com>
---
 CMakeLists.txt                   | 70 +++++++++++++++++++++++++++++---
 cmake/modules/InstallUtils.cmake | 12 ++++--
 samples/CMakeLists.txt           | 36 ++++++++++++----
 3 files changed, 100 insertions(+), 18 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index b2b83f68..66e7d8b1 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -116,15 +116,21 @@ if (WIN32)
 endif()
 
 if(CMAKE_INSTALL_PREFIX_INITIALIZED_TO_DEFAULT)
-  set(CMAKE_INSTALL_PREFIX ${TRT_LIB_DIR}/../ CACHE PATH "TensorRT installation" FORCE)
-endif(CMAKE_INSTALL_PREFIX_INITIALIZED_TO_DEFAULT)
+  # Default prefix is under the *build* directory (CMAKE_BINARY_DIR), not the source tree and not
+  # ${TRT_LIB_DIR}/.. (parent of the build dir). Packaging: cmake --install <build-dir> --prefix <dest>;
+  # Yocto/OpenEmbedded normally pass -DCMAKE_INSTALL_PREFIX=/usr so this block is skipped.
+  set(CMAKE_INSTALL_PREFIX "${CMAKE_BINARY_DIR}/install" CACHE PATH "TensorRT installation prefix" FORCE)
+endif()
 
 option(BUILD_PLUGINS "Build TensorRT plugin" ON)
 option(BUILD_PARSERS "Build TensorRT parsers" ON)
 option(BUILD_SAMPLES "Build TensorRT samples" ON)
+option(BUILD_TRTEXEC "Build trtexec (can be ON while BUILD_SAMPLES is OFF)" ON)
 option(BUILD_SAFE_SAMPLES "Build TensorRT safety samples" OFF)
 option(TRT_SAFETY_INFERENCE_ONLY "Build only the safety inference components (no safety builders)" OFF)
 
+include(cmake/modules/InstallUtils.cmake)
+
 ############################################################################################
 # Early dependency discovery
 # These must be found before they are used in target definitions
@@ -143,7 +149,30 @@ endif()
 
 ## find_package(CUDA) is broken for cross-compilation. Enable CUDA language instead.
 if(NOT DEFINED CMAKE_TOOLCHAIN_FILE)
-    find_package(CUDA ${CUDA_VERSION} REQUIRED)
+    find_package(CUDAToolkit REQUIRED)
+endif()
+
+# C++ targets include TensorRT headers that pull in CUDA (e.g. cuda_runtime_api.h). Populate
+# CUDA_INCLUDE_DIRS when a generic cross toolchain omits it (NVIDIA toolchains set it explicitly).
+if(NOT CUDA_INCLUDE_DIRS)
+    if(DEFINED CUDAToolkit_INCLUDE_DIRS AND CUDAToolkit_INCLUDE_DIRS)
+        set(CUDA_INCLUDE_DIRS ${CUDAToolkit_INCLUDE_DIRS})
+    elseif(DEFINED CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES AND CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES)
+        set(CUDA_INCLUDE_DIRS ${CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES})
+    elseif(DEFINED CUDA_TOOLKIT_ROOT_DIR)
+        set(CUDA_INCLUDE_DIRS "${CUDA_TOOLKIT_ROOT_DIR}/include")
+    endif()
+endif()
+if(NOT CUDA_INCLUDE_DIRS AND DEFINED CMAKE_TOOLCHAIN_FILE)
+    find_package(CUDAToolkit QUIET)
+    if(CUDAToolkit_FOUND AND CUDAToolkit_INCLUDE_DIRS)
+        set(CUDA_INCLUDE_DIRS ${CUDAToolkit_INCLUDE_DIRS})
+    endif()
+endif()
+if(NOT CUDA_INCLUDE_DIRS)
+    message(FATAL_ERROR
+        "CUDA include directory not found. When cross-compiling, set CUDA_INCLUDE_DIRS or "
+        "CUDA_TOOLKIT_ROOT_DIR, or pass -DCMAKE_CUDA_COMPILER= pointing at nvcc from a full toolkit.")
 endif()
 
 include_directories(
@@ -324,6 +353,9 @@ if (DEFINED USE_CUGFX)
     find_library(CUDART_LIB cugfx_dll HINTS ${CUDA_TOOLKIT_ROOT_DIR} PATH_SUFFIXES lib lib/x64 lib64)
 else()
     # DriveOS platforms use cudart.so instead of cudart_static. This isn't the most sophisticated check, but it's correct.
+    # For CUDA 12+, prefer libcudart_static.a. When cross-compiling, that archive must come from the target sysroot
+    # (e.g. Yocto recipe-sysroot); find_library with ONLY_CMAKE_FIND_ROOT_PATH avoids picking host libcudart_static.a
+    # from recipe-sysroot-native (wrong ELF machine / "file in wrong format").
     if(CUDA_VERSION VERSION_GREATER_EQUAL 12.0)
         set(CUDART_LIB_NAME cudart_static)
         set(CMAKE_CUDA_RUNTIME_LIBRARY "static")
@@ -341,7 +373,20 @@ else()
         set(CMAKE_CUDA_RUNTIME_LIBRARY "None")
     endif()
 
-    find_library(CUDART_LIB ${CUDART_LIB_NAME} HINTS ${CUDA_TOOLKIT_ROOT_DIR} PATH_SUFFIXES lib lib/x64 lib64)
+    if(CMAKE_CROSSCOMPILING)
+        # Yocto/OE: libcudart lives under the target sysroot, e.g.
+        # ${CMAKE_SYSROOT}/usr/local/cuda-${CUDA_VERSION}/lib/libcudart.so (not recipe-sysroot-native).
+        set(_trt_cudart_hints ${CUDA_TOOLKIT_ROOT_DIR})
+        if(CMAKE_SYSROOT)
+            list(APPEND _trt_cudart_hints "${CMAKE_SYSROOT}/usr/local/cuda-${CUDA_VERSION}")
+        endif()
+        find_library(CUDART_LIB ${CUDART_LIB_NAME} HINTS ${_trt_cudart_hints}
+            PATH_SUFFIXES lib lib64 lib/stubs
+            ONLY_CMAKE_FIND_ROOT_PATH)
+        unset(_trt_cudart_hints)
+    else()
+        find_library(CUDART_LIB ${CUDART_LIB_NAME} HINTS ${CUDA_TOOLKIT_ROOT_DIR} PATH_SUFFIXES lib lib/x64 lib64)
+    endif()
 endif()
 
 if (NOT MSVC)
@@ -350,6 +395,14 @@ endif()
 
 set(CUDA_LIBRARIES ${CUDART_LIB})
 
+# New plugin/samples flows link TRT::cudart. OSS does not ship a separate definition; some builds
+# alias it to CUDA::cudart from CUDAToolkit, which under Yocto often resolves to recipe-sysroot-native
+# (wrong arch). Back TRT::cudart with the same CUDART_LIB found above (ONLY_CMAKE_FIND_ROOT_PATH when cross).
+if(CUDART_LIB AND EXISTS "${CUDART_LIB}" AND NOT TARGET TRT::cudart)
+    add_library(TRT::cudart UNKNOWN IMPORTED GLOBAL)
+    set_target_properties(TRT::cudart PROPERTIES IMPORTED_LOCATION "${CUDART_LIB}")
+endif()
+
 ############################################################################################
 
 if(NOT MSVC)
@@ -381,6 +434,13 @@ endif()
 #   samples/CMakeLists.txt.
 # - BUILD_SAFE_SAMPLES controls the safety samples (builder + infer parts).
 #   Both can be enabled at the same time if desired.
-if(BUILD_SAMPLES OR BUILD_SAFE_SAMPLES)
+if(BUILD_SAMPLES OR BUILD_SAFE_SAMPLES OR BUILD_TRTEXEC)
     add_subdirectory(samples)
 endif()
+
+# Install rules place files under CMAKE_INSTALL_PREFIX; CMake resolves built binaries from
+# CMAKE_BINARY_DIR. Do not copy from CMAKE_SOURCE_DIR in packaging scripts.
+if(BUILD_SAMPLES OR BUILD_SAFE_SAMPLES OR BUILD_TRTEXEC)
+    message(STATUS "TensorRT: cmake --install \"${CMAKE_BINARY_DIR}\" (build dir). "
+                   "trtexec is COMPONENT external; other samples are internal.")
+endif()
diff --git a/cmake/modules/InstallUtils.cmake b/cmake/modules/InstallUtils.cmake
index d8806513..10f258b1 100644
--- a/cmake/modules/InstallUtils.cmake
+++ b/cmake/modules/InstallUtils.cmake
@@ -59,20 +59,24 @@ function(installLibraries)
     # When RUNTIME_ONLY is passed, we only want to install .dll files.
     # Instead of also installing the import library (.lib) files.
     # This is only relevant on Windows since Linux doesn't have this distinction.
+    set(_trt_install_dest "")
     if(ARG_RUNTIME_ONLY AND WIN32)
-        set(runtime_only_arg
+        set(_trt_install_dest RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR})
+    else()
+        # Required on Unix; without these, install(TARGETS) is invalid / no-op for executables.
+        set(_trt_install_dest
             RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR}
-        )
+            LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR}
+            ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR})
     endif()
 
-    # Install the libraries
     install(
         TARGETS ${ARG_TARGETS}
+        ${_trt_install_dest}
         ${optional_arg}
         ${component_arg}
         ${config_arg}
         ${export_arg}
-        ${runtime_only_arg}
     )
 
     # Install PDB files for MSVC builds
diff --git a/samples/CMakeLists.txt b/samples/CMakeLists.txt
index 482069ab..c06f4e03 100644
--- a/samples/CMakeLists.txt
+++ b/samples/CMakeLists.txt
@@ -15,13 +15,33 @@
 # limitations under the License.
 #
 
-# Require the ONNX parser to build samples or trtexec.
-if((${TRT_BUILD_SAMPLES} OR ${TRT_BUILD_TRTEXEC}) AND NOT ${TRT_BUILD_ONNX_PARSER})
-    message(FATAL_ERROR "Building trtexec (TRT_BUILD_TRTEXEC=${TRT_BUILD_TRTEXEC}) and/or the other samples (TRT_BUILD_SAMPLES=${TRT_BUILD_SAMPLES}) requires that TRT_BUILD_ONNX_PARSER=ON")
+# Map OSS BUILD_* options to TRT_BUILD_* names (enterprise may set TRT_BUILD_* before this file).
+if(NOT DEFINED TRT_BUILD_SAMPLES)
+    set(TRT_BUILD_SAMPLES "${BUILD_SAMPLES}")
+endif()
+if(NOT DEFINED TRT_BUILD_TRTEXEC)
+    set(TRT_BUILD_TRTEXEC "${BUILD_TRTEXEC}")
+endif()
+
+# Samples/trtexec link nvonnxparser. With BUILD_PARSERS=ON it is built from parsers/; with BUILD_PARSERS=OFF
+# the top-level CMake still imports it via find_library_create_target — do not require BUILD_PARSERS=ON.
+if((${TRT_BUILD_SAMPLES} OR ${TRT_BUILD_TRTEXEC}) AND NOT TARGET nvonnxparser)
+    message(FATAL_ERROR
+        "Building samples/trtexec requires the nvonnxparser CMake target. "
+        "With BUILD_PARSERS=OFF, ensure libnvonnxparser is found under TRT_LIB_DIR (or enable BUILD_PARSERS).")
 endif()
 
 if(${TRT_BUILD_ENABLE_NEW_SAMPLES_FLOW})
 
+# Build output: executables land under CMAKE_BINARY_DIR (not CMAKE_SOURCE_DIR). For installation,
+# use cmake --install "${CMAKE_BINARY_DIR}" so install(TARGETS ...) can find the built files.
+# TRT_SAMPLES_OUTPUT_DIR defaults to <build>/bin; global TRT_OUT_DIR is unchanged for libs/plugins.
+set(TRT_SAMPLES_OUTPUT_DIR "${CMAKE_BINARY_DIR}/bin" CACHE PATH
+    "Directory for TensorRT sample executables and trtexec (new samples flow only)")
+set(CMAKE_RUNTIME_OUTPUT_DIRECTORY "${TRT_SAMPLES_OUTPUT_DIR}")
+set(CMAKE_LIBRARY_OUTPUT_DIRECTORY "${TRT_SAMPLES_OUTPUT_DIR}")
+set(CMAKE_ARCHIVE_OUTPUT_DIRECTORY "${TRT_SAMPLES_OUTPUT_DIR}")
+
 # Setup aliases for ease of swapping between static/dynamic TRT.
 if(${TRT_BUILD_SAMPLES_LINK_STATIC_TRT})
     add_library(TRT_SAMPLES::tensorrt ALIAS tensorrt_static)
@@ -139,10 +159,6 @@ if(TARGET nvinfer)
     add_library(TRT_SAMPLES::tensorrt ALIAS nvinfer)
 endif()
 
-# Define installLibraries as a no-op for OSS builds
-function(installLibraries)
-endfunction()
-
 if(TRT_SAFETY_INFERENCE_ONLY)
     # Inference-only mode:
     # Only build the safety samples, skipping enterprise samples.
@@ -161,8 +177,11 @@ else()
         add_subdirectory(trtSafeExec)
     endif()
 
+    if(BUILD_TRTEXEC)
+        add_subdirectory(trtexec)
+    endif()
+
     if(BUILD_SAMPLES)
-        add_subdirectory(sampleCharRNN)
         add_subdirectory(sampleDynamicReshape)
         add_subdirectory(sampleEditableTimingCache)
         add_subdirectory(sampleINT8API)
@@ -172,7 +191,6 @@ else()
         add_subdirectory(sampleOnnxMNIST)
         add_subdirectory(sampleOnnxMnistCoordConvAC)
         add_subdirectory(sampleProgressMonitor)
-        add_subdirectory(trtexec)
 
         if(${TRT_BUILD_ENABLE_MULTIDEVICE})
             # Sample requires NCCL, which is not available when cross-compiling.
-- 
