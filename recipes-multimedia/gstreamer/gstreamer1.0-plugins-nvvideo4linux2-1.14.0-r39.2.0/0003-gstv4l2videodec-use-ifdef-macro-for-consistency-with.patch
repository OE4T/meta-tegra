From 9107311f88059b853d2760831f024d321ad9c8ec Mon Sep 17 00:00:00 2001
From: Ilies CHERGUI <ichergui@nvidia.com>
Date: Fri, 24 Apr 2026 07:40:32 -0700
Subject: [PATCH] gstv4l2videodec: use ifdef macro for consistency with the
 rest of the code

Upstream-Status: Pending
Signed-off-by: Jose Quaresma <quaresma.jose@gmail.com>
Signed-off-by: Ilies CHERGUI <ichergui@nvidia.com>
---
 gstv4l2videodec.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/gstv4l2videodec.c b/gstv4l2videodec.c
index e51d90c..c4184b4 100644
--- a/gstv4l2videodec.c
+++ b/gstv4l2videodec.c
@@ -736,7 +736,7 @@ gst_v4l2_video_dec_start (GstVideoDecoder * decoder)
   gst_v4l2_object_unlock (self->v4l2output);
   g_atomic_int_set (&self->active, TRUE);
   self->output_flow = GST_FLOW_OK;
-#if USE_V4L2_TARGET_NV
+#ifdef USE_V4L2_TARGET_NV
   self->decoded_picture_cnt = 0;
 #endif
 
@@ -1360,7 +1360,7 @@ gst_v4l2_video_dec_loop (GstVideoDecoder * decoder)
       gst_caps_unref(reference);
     }
 
-#if USE_V4L2_TARGET_NV
+#ifdef USE_V4L2_TARGET_NV
 
     GST_VIDEO_DECODER_STREAM_LOCK (decoder);
     if (!gst_buffer_copy_into (frame->output_buffer, frame->input_buffer,
